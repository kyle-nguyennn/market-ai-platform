{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FeatureVector",
  "type": "object",
  "required": ["symbol", "ts", "feature_set_version", "features"],
  "properties": {
    "symbol":              { "type": "string" },
    "ts":                  { "type": "string", "format": "date-time" },
    "feature_set_version": { "type": "string" },
    "features":            { "type": "object" }
  }
}
